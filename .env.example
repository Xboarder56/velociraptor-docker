# Copy this to `.env` and edit. `.env` is gitignored.
#
# Used by docker-compose.yaml at runtime. Do NOT put the image build
# version here — that lives in versions.env and the published image tag.

VELOX_DEFAULT_USER=admin
VELOX_DEFAULT_PASSWORD=changeme
VELOX_DEFAULT_USER_ROLE=administrator

# Public URL clients should reach the server on.
VELOX_FRONTEND_HOSTNAME=velociraptor.example.com
# VELOX_FRONTEND_PORT=8000
# VELOX_FRONTEND_SERVER_SCHEME=https

# Public URL for the admin GUI (only set if different from the client URL).
# VELOX_GUI_HOSTNAME=admin.example.com
# VELOX_GUI_PORT=8889
# VELOX_GUI_SCHEME=https
