# Source of truth for the image build.
# Updated automatically by .github/workflows/upstream-check.yml (PR) and
# read by .github/workflows/build-publish.yml.
#
# VELOX_VERSION  = Velocidex patch version this image is built from
#                  (filename component, e.g. v0.76.5). The minor tag the
#                  asset lives under (v0.76) is derived by stripping the
#                  patch suffix.
# IMAGE_REVISION = our own re-release counter (bump when we fix something
#                  on our side against the same upstream version)
VELOX_VERSION=v0.76.5
IMAGE_REVISION=2
